# python
__pycache__/
*.py[cod]
.venv/
venv/
*.egg-info/

# public datasets are large; do not commit raw/processed data
data/raw/*
data/processed/*
!data/raw/.gitkeep
!data/processed/.gitkeep

# model weights / checkpoints
*.pt
*.pth
*.ckpt
checkpoints/

# os / editor
.DS_Store
.idea/
.vscode/

# raw EuRoC sequence data lives under data/<seq>/; never commit it
data/*/
!data/raw/
!data/processed/
# track only the metric CSVs the README cites, not everything in results/
results/*
!results/baseline_segment_drift.csv